# Wallet Connect (optional — falls back to injected wallets without it)
NEXT_PUBLIC_WC_PROJECT_ID=

# World ID — create at https://developer.worldcoin.org
# Create an action named "enter-arena" in the developer portal
NEXT_PUBLIC_WORLDCOIN_APP_ID=
WORLDCOIN_APP_ID=

# MatchVault contract (after deploying to Base Sepolia)
NEXT_PUBLIC_MATCH_VAULT_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=

# Server-side resolver wallet (calls resolveMatch on-chain)
RESOLVER_PRIVATE_KEY=

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=
