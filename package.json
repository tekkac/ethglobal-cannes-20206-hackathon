{
  "name": "tunis-v3",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test && forge test --root contracts",
    "contracts:test": "forge test --root contracts",
    "db:generate": "pnpm --filter web db:generate",
